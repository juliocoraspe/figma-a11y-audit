{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "outDir": "dist/cli",
    "noEmit": false,
    "types": [],
    "lib": ["ES2022"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/cli/**/*.ts",
    "src/shared/**/*.ts",
    "src/sandbox/detect/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src/ui/**", "src/sandbox/main.ts", "src/sandbox/bridge/**", "src/sandbox/overlay/**"]
}
