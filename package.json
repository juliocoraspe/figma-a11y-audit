{
  "name": "a11y-figma-audit",
  "version": "1.0.0",
  "private": false,
  "description": "Figma plugin that audits design files against WCAG 2.1/2.2 AA",
  "author": "Julio Coraspe",
  "license": "MIT",
  "scripts": {
    "dev": "VITE_BUILD_TARGET=ui vite build --watch --mode development",
    "build": "tsc --noEmit && VITE_BUILD_TARGET=ui vite build && VITE_BUILD_TARGET=sandbox vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --dir src/sandbox/detect",
    "cli": "tsx src/cli/index.ts",
    "cli:build": "tsc -p tsconfig.cli.json"
  },
  "bin": {
    "a11y-figma-audit": "dist/cli/index.js"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.108.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "commander": "14.0.3",
    "tsx": "4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^2.1.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
